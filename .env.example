# HuggingFace — required to download gated models (Llama, Mistral)
HF_TOKEN=hf_your_token_here

# Base model to fine-tune (swap without changing any code)
MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
# MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2
# MODEL_NAME=meta-llama/Llama-3.2-1B-Instruct

# Experiment tracking — set to enable WandB logging (optional)
WANDB_API_KEY=
WANDB_PROJECT=finetune-lora-dpo
WANDB_ENTITY=

# Training output directories
SFT_OUTPUT_DIR=./checkpoints/sft
DPO_OUTPUT_DIR=./checkpoints/dpo

# Quantisation — set false if you have ≥ 40GB VRAM and want full bfloat16
LOAD_IN_4BIT=true

# Evaluation
EVAL_MAX_SAMPLES=1000
